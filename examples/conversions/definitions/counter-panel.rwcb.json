{
  "tagName": "demo-counter-panel",
  "component": "CounterPanel",
  "options": {
    "shadow": { "mode": "open" },
    "props": {
      "initialCount": { "attribute": "initial-count", "type": "number" },
      "step": { "type": "number", "reflect": true }
    },
    "events": {
      "onCountChange": { "name": "count-change" }
    },
    "styles": ":host{display:inline-block}.counter-panel{display:inline-grid;grid-template-columns:2rem 4rem 2rem;gap:.5rem;align-items:center}output{text-align:center;font-weight:700}"
  }
}
