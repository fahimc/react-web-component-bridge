{
  "name": "@codedia/react-to-web-component-compiler",
  "version": "0.1.2",
  "description": "Metadata generator for @codedia/react-to-web-component-runtime definitions.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://react-web-component-bridge-site.netlify.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fahimc/react-to-web-component-compiler.git",
    "directory": "packages/generator"
  },
  "bugs": {
    "url": "https://github.com/fahimc/react-to-web-component-compiler/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "react-to-web-component-compiler": "./dist/cli.cjs",
    "react-web-component-bridge": "./dist/cli.cjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "dependencies": {
    "@codedia/react-to-web-component-runtime": "workspace:*",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --sourcemap --clean && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
