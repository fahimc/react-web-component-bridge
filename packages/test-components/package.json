{
  "name": "@codedia/react-to-web-component-test-components",
  "version": "0.1.4",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./web-components": {
      "types": "./dist/web-components.d.ts",
      "import": "./dist/web-components.js",
      "require": "./dist/web-components.cjs"
    }
  },
  "dependencies": {
    "@codedia/react-to-web-component-runtime": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "scripts": {
    "build": "tsup src/index.tsx src/web-components.ts --format esm,cjs --sourcemap --clean && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
